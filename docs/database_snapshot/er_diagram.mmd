erDiagram
%% DBスナップショット — ER図 (Mermaid)。make db-snapshot で自動生成。手動編集しない。
%% 外部キー制約は張らない方針のため、関連は <table>_id 命名からの推論（論理リレーション）。
    alert_histories {
        INTEGER id PK
        INTEGER alert_rule_id FK
        VARCHAR metric
        VARCHAR operator
        REAL threshold
        REAL actual_value
        BOOLEAN is_notified
        DATETIME triggered_at
        DATETIME created_at
        DATETIME updated_at
        DATETIME deleted_at
    }
    alert_rules {
        INTEGER id PK
        INTEGER device_id FK
        VARCHAR metric
        VARCHAR operator
        REAL threshold
        BOOLEAN is_enabled
        DATETIME created_at
        DATETIME updated_at
        DATETIME deleted_at
    }
    device_tokens {
        INTEGER id PK
        INTEGER user_id FK
        VARCHAR name
        VARCHAR token_hash
        json abilities
        DATETIME last_used_at
        DATETIME expires_at
        DATETIME created_at
        DATETIME updated_at
    }
    devices {
        INTEGER id PK
        INTEGER user_id FK
        VARCHAR name
        VARCHAR mac_address
        VARCHAR location
        BOOLEAN is_active
        DATETIME last_communicated_at
        DATETIME created_at
        DATETIME updated_at
        DATETIME deleted_at
    }
    sensor_readings {
        INTEGER id PK
        INTEGER device_id FK
        REAL temperature
        REAL humidity
        DATETIME recorded_at
        DATETIME created_at
        DATETIME updated_at
        DATETIME deleted_at
    }
    sessions {
        TEXT token PK
        BLOB data
        REAL expiry
    }
    users {
        INTEGER id PK
        VARCHAR name
        VARCHAR email
        VARCHAR password_hash
        DATETIME email_verified_at
        DATETIME created_at
        DATETIME updated_at
    }
    alert_rules ||--o{ alert_histories : alert_rule_id
    devices ||--o{ alert_rules : device_id
    users ||--o{ device_tokens : user_id
    users ||--o{ devices : user_id
    devices ||--o{ sensor_readings : device_id
