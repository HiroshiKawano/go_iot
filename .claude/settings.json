{
  "permissions": {
    "allow": [
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(go vet:*)",
      "Bash(go doc:*)",
      "Bash(go list:*)",
      "Bash(go fmt:*)",
      "Bash(go env:*)",
      "Bash(go version:*)",
      "Bash(go mod download:*)",
      "Bash(go mod verify:*)",
      "Bash(go mod tidy:*)",
      "Bash(go get:*)",
      "Bash(go tool templ:*)",
      "Bash(go tool cover:*)",
      "Bash(go run:*)",
      "Bash(gofmt:*)",
      "Bash(templ:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(tr:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(jq:*)",
      "Bash(diff:*)",
      "Bash(which:*)",
      "Bash(lsof:*)",
      "Bash(tree:*)",
      "Bash(seq:*)",
      "Bash(sleep:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(cd:*)",
      "Bash(set:*)",
      "Bash(export:*)",
      "Bash(curl:*)",
      "Bash(python3:*)",
      "Bash(docker compose exec:*)",
      "Bash(docker exec:*)",
      "Bash(docker version:*)",
      "Bash(make:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout internal/:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(perl:*)",
      "Bash(md5:*)",
      "Bash(md5sum:*)",
      "Bash(git ls-files:*)",
      "Bash(git worktree:*)",
      "Bash(git checkout HEAD -- internal/:*)",
      "Bash(git restore:*)",
      "Bash(mkdir:*)",
      "Bash(rmdir:*)",
      "Bash(cut:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-source-redirect.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/bash-rm-guard.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-force-push.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-cc-sdd-refs.sh\""
          }
        ]
      }
    ]
  }
}
