# アプリケーション設定
APP_ENV=development
APP_PORT=8080

# SQLite データベースファイル (file: DSN 形式)。WAL/busy_timeout/foreign_keys は接続層(infra/db)が自動付与。
# マイグレーションは手動適用 (S9 段階。起動時自動適用・単一exe配布は S10)。
DATABASE_URL=file:./go_iot.sqlite

# セッション署名鍵 (本番では 32 文字以上のランダム値に変更すること)
SESSION_SECRET=dev-only-change-me-in-production-0123456789

# デバイス API トークン関連 (将来拡張用)
DEVICE_TOKEN_SECRET=dev-only-device-token-secret
