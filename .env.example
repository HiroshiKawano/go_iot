# アプリケーション設定
APP_ENV=development
APP_PORT=8080

# PostgreSQL 接続 URL (docker-compose の DB を参照)
DATABASE_URL=postgres://go_iot:go_iot_dev@localhost:5432/go_iot?sslmode=disable

# セッション署名鍵 (本番では 32 文字以上のランダム値に変更すること)
SESSION_SECRET=dev-only-change-me-in-production-0123456789

# デバイス API トークン関連 (将来拡張用)
DEVICE_TOKEN_SECRET=dev-only-device-token-secret
