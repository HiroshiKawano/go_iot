# go_iot 設定例 (.env)
#
# 重要: env は「任意」です。.env が無く環境変数も未設定でも、アプリは起動できます
# (ゼロ設定起動)。その場合、DB ファイル・CSRF 認証鍵・ログはアプリデータ配下
# (Windows: %LOCALAPPDATA%\go_iot\、macOS/Linux: ~/.config/go_iot/ 等) に自動作成され、
# 起動時にマイグレーションが自動適用されます。下記は既定値を上書きしたい場合にのみ設定します。

# アプリケーション環境 (development / production)。未設定時は development 相当。
APP_ENV=development

# 待受ポート。未設定時は 8080。使用中なら空きポートを自動採番します。
APP_PORT=8080

# SQLite データベースファイル (file: DSN 形式)。未設定時はアプリデータ配下の app.db を
# forward-slash 化した file: URI で自動構築します。WAL/busy_timeout/foreign_keys は接続層
# (internal/infra/db) が自動付与するため DSN に含める必要はありません。
# DATABASE_URL=file:./go_iot.sqlite

# CSRF 認証鍵 (要件上は SESSION_SECRET)。未設定時はアプリデータ配下に 32 バイトの乱数を
# base64 で自動生成・永続化し、再起動後も再利用します。production では文字数 32 以上が必須
# (自動生成鍵は 32 バイト=base64 44 文字。手動指定する場合も 44 文字以上を推奨)。
# SESSION_SECRET=change-me-in-production-0123456789abcdef

# デバイス API トークン関連 (将来拡張用)。
# DEVICE_TOKEN_SECRET=dev-only-device-token-secret

# ログ出力先の上書き (任意)。未設定時、GUI ビルドはアプリデータ配下 app.log、console ビルドは標準出力。
# LOG_FILE=
